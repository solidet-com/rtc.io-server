{
  "name": "rtc.io-server",
  "version": "1.2.0",
  "description": "Signaling server for the rtc.io WebRTC client. Built on socket.io.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "rtc.io",
    "webrtc",
    "signaling",
    "socket.io",
    "server"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/<your-org>/rtc.io.git",
    "directory": "rtc.io-server"
  },
  "bugs": {
    "url": "https://github.com/<your-org>/rtc.io/issues"
  },
  "homepage": "https://github.com/<your-org>/rtc.io#readme",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "dev": "nodemon --watch '**/*.ts' --exec 'ts-node' ./index.ts",
    "prepack": "npm run build"
  },
  "dependencies": {
    "socket.io": "^4.7.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.9.3"
