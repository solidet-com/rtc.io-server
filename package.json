{
	"name": "rtcio-server",
	"version": "0.0.1",
	"description": "WebRTC  + socket.io components for Node.js",
	"keywords": [
		"webrtc",
		"server",
		"rtc.io",
		"signalling server",
		"websocket",
		"realtime",
		"framework",
		"tcp",
		"events",
		"socket",
		"io"
	],
	"scripts": {
		"build": "tsc",
		"start": "node dist/index.js",
		"dev": "nodemon --watch '**/*.ts' --exec 'ts-node' ./index.ts"
	},
	"dependencies": {
		"express": "^4.18.2",
		"socket.io": "^4.7.2",
		"socket.io-client": "^4.7.2"
	},
	"devDependencies": {
		"@types/express": "^4.17.13",
		"@types/node": "^16.11.7",
		"@types/ws": "^8.0.4",
		"nodemon": "^3.0.2",
		"prettier": "^3.0.3",
		"ts-node": "^10.9.2",
		"typescript": "^5.2.2"
	}
}
